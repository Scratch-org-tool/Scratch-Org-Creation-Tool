generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum OrgType {
  scratch
  sandbox
  prod
}

enum OrgStatus {
  active
  expired
  revoked
  authorizing
}

enum JobStatus {
  pending
  queued
  planning
  running
  paused
  awaiting_input
  completed
  partial
  failed
  cancelled
}

enum DeploymentStrategy {
  azure
  jenkins
}

enum LogStream {
  stdout
  stderr
}

model OrgConnection {
  id              String    @id @default(uuid())
  alias           String    @unique
  type            OrgType   @default(scratch)
  instanceUrl     String
  username        String?
  orgId           String?
  loginUrl        String?
  accessToken     String?
  refreshToken    String?
  isDevHub        Boolean   @default(false)
  isDefaultDevHub Boolean   @default(false)
  status          OrgStatus @default(authorizing)
  expiresAt       DateTime?
  createdBy       String    @default("system")
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  sourceMovements         DataMovement[]      @relation("SourceOrg")
  targetMovements         DataMovement[]      @relation("TargetOrg")
  deployments             Deployment[]
  provisionBatches        ProvisioningBatch[]
  dataDeployBatchesSource DataDeployBatch[]   @relation("BatchSourceOrg")
  dataDeployBatchesTarget DataDeployBatch[]   @relation("BatchTargetOrg")
  automationRunsTarget     AutomationRun[]    @relation("AutomationRunTarget")
  releases                Release[]           @relation("ReleaseTargetOrg")

  @@index([createdBy])
}

model AutomationRun {
  id                    String         @id @default(uuid())
  intent                String
  status                JobStatus      @default(pending)
  createdBy             String         @default("system")
  config                Json?
  failedStep            String?
  lastError             String?
  checkpoint            Json?
  launchMode            String         @default("create_new")
  targetOrgConnectionId String?
  targetOrgConnection   OrgConnection? @relation("AutomationRunTarget", fields: [targetOrgConnectionId], references: [id])
  createdAt             DateTime       @default(now())
  updatedAt             DateTime       @updatedAt
  jobs                  Job[]

  @@index([createdBy])
  @@index([targetOrgConnectionId, status])
}

model Job {
  id          String         @id @default(uuid())
  queue       String
  type        String
  payload     Json
  status      JobStatus      @default(pending)
  currentStep String         @default("Not Started")
  alias       String?
  attempts    Int            @default(0)
  error       String?
  parentRunId String?
  parentRun   AutomationRun? @relation(fields: [parentRunId], references: [id], onDelete: Cascade)
  createdBy   String         @default("system")
  startedAt   DateTime?
  finishedAt  DateTime?
  createdAt   DateTime       @default(now())
  updatedAt   DateTime       @updatedAt
  logs        JobLog[]
  scratchOrg  ScratchOrg?
  deployment  Deployment?

  @@index([parentRunId])
  @@index([status])
  @@index([queue])
  @@index([alias])
  @@index([createdBy])
}

model ScratchOrg {
  id             String    @id @default(uuid())
  alias          String    @unique
  username       String
  password       String?
  orgId          String?
  instanceUrl    String?
  loginUrl       String?
  expirationDate DateTime?
  devHubAlias    String?
  status         String    @default("Active")
  jobId          String?   @unique
  job            Job?      @relation(fields: [jobId], references: [id])
  createdBy      String    @default("system")
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt

  @@index([createdBy])
}

model JobLog {
  id        String    @id @default(uuid())
  jobId     String
  job       Job       @relation(fields: [jobId], references: [id], onDelete: Cascade)
  timestamp DateTime  @default(now())
  stream    LogStream @default(stdout)
  line      String

  @@index([jobId])
}

model Deployment {
  id           String             @id @default(uuid())
  sourceOrgId  String?
  targetOrgId  String
  targetOrg    OrgConnection      @relation(fields: [targetOrgId], references: [id])
  jobId        String?            @unique
  job          Job?               @relation(fields: [jobId], references: [id])
  repo         String
  branch       String
  strategy     DeploymentStrategy
  status       JobStatus          @default(pending)
  approvedBy   String?
  approvedAt   DateTime?
  metadata     Json?
  /// Salesforce deploy request id from a validate-only run, usable for quick deploy.
  validationId String?
  /// Path to the pre-deploy snapshot of affected components retrieved from the target org.
  snapshotPath String?
  createdBy    String             @default("system")
  createdAt    DateTime           @default(now())
  updatedAt    DateTime           @updatedAt
  rollbacks    Rollback[]
  qualityRuns  DeploymentQualityRun[]

  @@index([createdBy])
}

model MetadataComparison {
  id          String    @id @default(uuid())
  sourceOrgId String
  targetOrgId String
  status      JobStatus @default(pending)
  summary     Json?
  items       Json?
  diffCache   Json?
  createdBy   String    @default("system")
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  @@index([createdBy])
  @@index([sourceOrgId, targetOrgId])
}

model Rollback {
  id           String     @id @default(uuid())
  deploymentId String
  deployment   Deployment @relation(fields: [deploymentId], references: [id], onDelete: Cascade)
  reason       String?
  status       JobStatus  @default(pending)
  createdAt    DateTime   @default(now())
}

model DataMovement {
  id                 String           @id @default(uuid())
  sourceOrgId        String
  sourceOrg          OrgConnection    @relation("SourceOrg", fields: [sourceOrgId], references: [id])
  targetOrgId        String
  targetOrg          OrgConnection    @relation("TargetOrg", fields: [targetOrgId], references: [id])
  objectName         String?
  soql               String?
  recordCount        Int?
  sfdmuConfig        Json?
  recordTypeMappings Json?
  status             JobStatus        @default(pending)
  movementType       String           @default("deploy")
  operation          String           @default("insert")
  externalIdField    String?
  idempotent         Boolean          @default(false)
  rollbackArtifact   Json?
  rollbackReport     Json?
  rollbackStatus     String?
  durableRollback    DataRollbackArtifact?
  batchId            String?
  batch              DataDeployBatch? @relation(fields: [batchId], references: [id], onDelete: SetNull)
  chunkIndex         Int?
  createdBy          String           @default("system")
  createdAt          DateTime         @default(now())
  updatedAt          DateTime         @updatedAt

  @@index([createdBy])
  @@index([batchId])
}

/// Encrypted pre-write rollback snapshot. The unique movement relation makes
/// the first completed capture immutable across queue retries and API replicas.
model DataRollbackArtifact {
  id                String       @id @default(uuid())
  movementId        String       @unique
  movement          DataMovement @relation(fields: [movementId], references: [id], onDelete: Cascade)
  ciphertext        Bytes
  algorithm         String       @default("aes-256-gcm+gzip")
  iv                String
  authTag           String
  sha256            String
  compressedBytes   Int
  uncompressedBytes Int
  previousCount     Int
  insertedCount     Int
  expiresAt         DateTime
  createdAt         DateTime     @default(now())

  @@index([expiresAt])
}

model DataDeployBatch {
  id                 String            @id @default(uuid())
  /// Groups multiple per-object batches created from one multi-object deploy request.
  groupId            String?
  sourceOrgId        String
  sourceOrg          OrgConnection     @relation("BatchSourceOrg", fields: [sourceOrgId], references: [id])
  targetOrgId        String
  targetOrg          OrgConnection     @relation("BatchTargetOrg", fields: [targetOrgId], references: [id])
  objectName         String?
  objectKey          String?
  dependsOn          String[]          @default([])
  strategy           String            @default("generic")
  operation          String            @default("insert")
  externalIdField    String?
  idempotent         Boolean           @default(false)
  movementType       String            @default("deploy")
  status             JobStatus         @default(queued)
  baseSoql           String?
  matchField         String?
  recordTypeMappings Json?
  /// Upper bound requested by the user; totalRecords becomes the matched/planned count.
  requestedRecords   Int               @default(0)
  totalRecords       Int               @default(0)
  chunkSize          Int               @default(25000)
  totalChunks        Int               @default(1)
  completedChunks    Int               @default(0)
  failedChunks       Int               @default(0)
  plannerJobId       String?
  maxParallelChunks  Int               @default(4)
  quotaRemaining     Int?
  quotaConfidence    String            @default("unknown")
  boundaryArtifact   Json?
  rollbackPolicy     String            @default("none")
  rollbackArtifact   Json?
  rollbackReport     Json?
  rollbackStatus     String?
  error              String?
  createdBy          String            @default("system")
  createdAt          DateTime          @default(now())
  updatedAt          DateTime          @updatedAt
  chunks             DataDeployChunk[]
  movements          DataMovement[]

  @@index([createdBy])
  @@index([status])
  @@index([groupId])
}

model DataDeployChunk {
  id          String          @id @default(uuid())
  batchId     String
  batch       DataDeployBatch @relation(fields: [batchId], references: [id], onDelete: Cascade)
  chunkIndex  Int
  soql        String
  /// Exclusive lower Id bound resolved by the batch planner (keyset pagination).
  afterId     String?
  /// Inclusive upper Id bound resolved by the batch planner.
  endId       String?
  movementId  String?
  jobId       String?
  status      JobStatus       @default(queued)
  recordCount Int?
  /// Records explicitly reported by the write engine, when available.
  processedRecords Int?
  failedRecords    Int?
  error       String?
  errorDetails Json?
  attempts    Int             @default(0)
  createdAt   DateTime        @default(now())
  updatedAt   DateTime        @updatedAt

  @@unique([batchId, chunkIndex])
  @@index([batchId])
  @@index([jobId])
}

model ProvisioningBatch {
  id           String            @id @default(uuid())
  orgId        String
  org          OrgConnection     @relation(fields: [orgId], references: [id])
  status       JobStatus         @default(pending)
  totalRows    Int               @default(0)
  successCount Int               @default(0)
  failCount    Int               @default(0)
  createdBy    String            @default("system")
  createdAt    DateTime          @default(now())
  updatedAt    DateTime          @updatedAt
  users        ProvisionedUser[]

  @@index([createdBy])
}

model ProvisionedUser {
  id             String            @id @default(uuid())
  batchId        String
  batch          ProvisioningBatch @relation(fields: [batchId], references: [id], onDelete: Cascade)
  firstName      String
  lastName       String
  email          String
  username       String
  profile        String?
  role           String?
  permissionSets String[]
  status         JobStatus         @default(pending)
  error          String?
  sfUserId       String?
  createdAt      DateTime          @default(now())

  @@unique([batchId, username])
}

model KnowledgeChunk {
  id         String   @id @default(uuid())
  source     String
  sourceType String
  /// Access tier: 'app_guide' (usage help, safe for granted users) or 'internal' (code/architecture, admin only).
  tier       String   @default("internal")
  content    String
  metadata   Json?
  embedding  Json?
  createdAt  DateTime @default(now())

  @@index([sourceType])
  @@index([tier])
}

/// Immutable audit trail for metadata deployments (validate / deploy / quick-deploy / rollback).
model DeploymentAudit {
  id             String   @id @default(uuid())
  deploymentId   String?
  action         String
  sourceOrgId    String?
  targetOrgId    String?
  repo           String?
  branch         String?
  manifestHash   String?
  componentCount Int?
  components     Json?
  testLevel      String?
  validationId   String?
  status         String
  error          String?
  performedBy    String   @default("system")
  createdAt      DateTime @default(now())

  @@index([deploymentId])
  @@index([performedBy])
  @@index([createdAt])
}

/// Saved, reusable deployment definition — the seam for future automation
/// (scheduled promotions, webhooks, approval gates).
model DeploymentPlan {
  id                 String              @id @default(uuid())
  name               String
  description        String?
  sourceOrgId        String?
  targetOrgId        String?
  planType           String              @default("combined")
  metadataConfig     Json?
  dataConfig         Json?
  enabled            Boolean             @default(true)
  /// Structured automation schedule (see @sfcc/shared DeploymentSchedule). Null = manual only.
  schedule           Json?
  scheduleEnabled    Boolean             @default(false)
  /// Next time the scheduler should fire this plan; claimed atomically per tick.
  nextRunAt          DateTime?
  lastScheduledRunAt DateTime?
  lastRunAt          DateTime?
  lastRunStatus      String?
  createdBy          String              @default("system")
  createdAt          DateTime            @default(now())
  updatedAt          DateTime            @updatedAt
  runs               DeploymentPlanRun[]

  @@index([createdBy])
  @@index([scheduleEnabled, nextRunAt])
}

/// One execution of a saved plan — manual or scheduled — for run history.
model DeploymentPlanRun {
  id              String         @id @default(uuid())
  planId          String
  plan            DeploymentPlan @relation(fields: [planId], references: [id], onDelete: Cascade)
  trigger         String         @default("manual")
  status          String         @default("started")
  planType        String?
  jobId           String?
  automationRunId String?
  error           String?
  createdBy       String         @default("system")
  startedAt       DateTime       @default(now())
  finishedAt      DateTime?

  @@index([planId, startedAt])
}

/// A recurring source-vs-target org comparison that records drift snapshots
/// and (optionally) alerts the owner when new differences appear.
model DriftMonitor {
  id              String          @id @default(uuid())
  name            String
  description     String?
  sourceOrgId     String
  targetOrgId     String
  metadataTypes   String[]        @default([])
  schedule        Json?
  scheduleEnabled Boolean         @default(false)
  enabled         Boolean         @default(true)
  notifyOnDrift   Boolean         @default(true)
  nextRunAt       DateTime?
  lastCheckedAt   DateTime?
  lastStatus      String?
  lastDriftCount  Int?
  createdBy       String          @default("system")
  createdAt       DateTime        @default(now())
  updatedAt       DateTime        @updatedAt
  snapshots       DriftSnapshot[]

  @@index([createdBy])
  @@index([scheduleEnabled, nextRunAt])
}

/// A single drift check result. Only differing components are stored in `items`.
model DriftSnapshot {
  id               String       @id @default(uuid())
  monitorId        String
  monitor          DriftMonitor @relation(fields: [monitorId], references: [id], onDelete: Cascade)
  status           String       @default("clean")
  trigger          String       @default("schedule")
  totalDifferences Int          @default(0)
  added            Int          @default(0)
  changed          Int          @default(0)
  removed          Int          @default(0)
  byType           Json?
  items            Json?
  newlyDrifted     Json?
  error            String?
  createdBy        String       @default("system")
  createdAt        DateTime     @default(now())

  @@index([monitorId, createdAt])
}

/// Planning and quality-policy record for the provider-neutral Deployment Workbench.
/// Execution workers may attach a legacy Deployment later; planning itself has no side effects.
model DeploymentQualityRun {
  id                    String                        @id @default(uuid())
  deploymentId          String?
  deployment            Deployment?                   @relation(fields: [deploymentId], references: [id], onDelete: SetNull)
  name                  String?
  description           String?
  source                Json
  targetOrgId           String
  targetProfile         String
  strategy              String
  components            Json
  manifestXml           String?
  apiVersion            String?
  destructiveSelections Json
  dependencyPolicy      Json
  chainedData           Json?
  policySnapshot        Json
  stagePlan             Json
  status                String                        @default("planned")
  currentStage          String?
  summary               Json?
  artifacts             Json?
  validationId          String?
  executionLease        String?
  approvedBy            String?
  approvedAt            DateTime?
  rejectedBy            String?
  rejectedAt            DateTime?
  rejectionReason       String?
  createdBy             String                        @default("system")
  createdAt             DateTime                      @default(now())
  updatedAt             DateTime                      @updatedAt
  stages                DeploymentQualityStage[]
  issues                DeploymentQualityIssue[]
  testResults           DeploymentQualityTestResult[]
  audits                DeploymentQualityAudit[]
  approvals             DeploymentQualityApproval[]
  destructiveReviews   DeploymentDestructiveReview[]

  @@index([createdBy, createdAt])
  @@index([targetOrgId, status])
  @@index([deploymentId])
  @@index([validationId])
}

/// Immutable, content-addressed Workbench bytes. The database implementation is
/// the default durable object store; callers only retain this checksum key.
model DeploymentArtifact {
  id          String   @id
  kind        String
  checksum    String
  content     Bytes
  sizeBytes   Int
  metadata    Json?
  createdAt   DateTime @default(now())
  retainUntil DateTime?

  @@index([kind, createdAt])
  @@index([retainUntil])
}

/// One actor can contribute at most one approval to a run.
model DeploymentQualityApproval {
  id        String               @id @default(uuid())
  runId     String
  run       DeploymentQualityRun @relation(fields: [runId], references: [id], onDelete: Cascade)
  actorId   String
  createdAt DateTime             @default(now())

  @@unique([runId, actorId])
  @@index([runId, createdAt])
}

/// Explicit, hash-bound destructive decisions are independent from plan approval.
model DeploymentDestructiveReview {
  id        String               @id @default(uuid())
  runId     String
  run       DeploymentQualityRun @relation(fields: [runId], references: [id], onDelete: Cascade)
  actorId   String
  digest    String
  approved  Boolean
  createdAt DateTime             @default(now())

  @@unique([runId, actorId, digest])
  @@index([runId, digest, approved])
}

model DeploymentQualityStage {
  id          String                        @id @default(uuid())
  runId       String
  run         DeploymentQualityRun          @relation(fields: [runId], references: [id], onDelete: Cascade)
  key         String
  ordinal     Int
  required    Boolean                       @default(true)
  status      String                        @default("pending")
  startedAt   DateTime?
  finishedAt  DateTime?
  durationMs  Int?
  summary     Json?
  artifacts   Json?
  error       String?
  createdAt   DateTime                      @default(now())
  updatedAt   DateTime                      @updatedAt
  issues      DeploymentQualityIssue[]
  testResults DeploymentQualityTestResult[]

  @@unique([runId, key])
  @@unique([runId, ordinal])
  @@index([runId, status])
}

model DeploymentQualityIssue {
  id          String                  @id @default(uuid())
  runId       String
  run         DeploymentQualityRun    @relation(fields: [runId], references: [id], onDelete: Cascade)
  stageId     String?
  stage       DeploymentQualityStage? @relation(fields: [stageId], references: [id], onDelete: SetNull)
  engine      String
  ruleId      String
  severity    String
  message     String
  component   String?
  file        String?
  line        Int?
  column      Int?
  fingerprint String?
  helpUrl     String?
  metadata    Json?
  createdAt   DateTime                @default(now())

  @@index([runId, severity])
  @@index([stageId])
  @@index([engine, ruleId])
}

model DeploymentQualityTestResult {
  id          String                  @id @default(uuid())
  runId       String
  run         DeploymentQualityRun    @relation(fields: [runId], references: [id], onDelete: Cascade)
  stageId     String?
  stage       DeploymentQualityStage? @relation(fields: [stageId], references: [id], onDelete: SetNull)
  className   String
  methodName  String
  status      String
  durationMs  Int?
  message     String?
  stackTrace  String?
  diagnostics Json?
  coverage    Json?
  createdAt   DateTime                @default(now())

  @@index([runId, status])
  @@index([stageId])
  @@index([className])
}

/// Append-only decisions and policy lifecycle events for a workbench run.
model DeploymentQualityAudit {
  id        String               @id @default(uuid())
  runId     String
  run       DeploymentQualityRun @relation(fields: [runId], references: [id], onDelete: Cascade)
  action    String
  actorId   String
  details   Json?
  createdAt DateTime             @default(now())

  @@index([runId, createdAt])
  @@index([actorId, createdAt])
}

model OrgSetupRun {
  id        String    @id @default(uuid())
  orgId     String
  setupType String
  config    Json
  status    JobStatus @default(pending)
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
}

enum AppUserRole {
  admin
  user
}

enum ScmProvider {
  azure_devops
  github
  bitbucket
}

enum WorkItemProvider {
  azure_boards
  github_issues
  jira
}

enum IntegrationConnectionStatus {
  connected
  degraded
  disconnected
  error
}

model AppUser {
  id             String      @id
  email          String
  displayName    String
  role           AppUserRole @default(user)
  grantedModules String[]    @default([])
  status         String      @default("active")
  lastActiveAt   DateTime?
  /// Personal opt-in for outbound email alerts (work-item updates, job
  /// notifications). Off by default — the user must explicitly enable it and
  /// the admin email channel must also be on before anything is sent.
  emailNotifications Boolean @default(false)
  createdAt      DateTime    @default(now())
  updatedAt      DateTime    @updatedAt

  @@index([email])
  @@index([status])
}

/// Per-user notification inbox entry. Rows are only created when an
/// administrator has enabled notifications and the relevant category is on.
model Notification {
  id        String    @id @default(uuid())
  userId    String
  category  String    @default("system")
  level     String    @default("info")
  title     String
  body       String?
  link      String?
  jobId     String?
  metadata  Json?
  readAt    DateTime?
  createdAt DateTime  @default(now())

  @@index([userId, createdAt])
  @@index([userId, readAt])
}

/// Global, admin-owned notification controls. A single "global" row decides
/// whether notifications are sent at all, which channels deliver, and which
/// categories are active. Absent row => notifications are off.
model NotificationSetting {
  id         String   @id @default("global")
  enabled    Boolean  @default(false)
  channels   Json     @default("{\"inApp\":true,\"email\":false}")
  categories Json     @default("{\"deployment\":true,\"data\":true,\"environment\":true,\"provisioning\":true,\"system\":true}")
  updatedBy  String?
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
}

/// Security audit trail. Metadata must never contain credentials, bearer
/// tokens, passwords, raw IP addresses, or raw user-agent values.
model AuthAuditEvent {
  id            String   @id @default(uuid())
  userId        String?
  eventType     String
  metadata      Json?
  ipHash        String?
  userAgentHash String?
  createdAt     DateTime @default(now())

  @@index([userId, createdAt])
  @@index([eventType, createdAt])
  @@index([createdAt])
}

/// Short-lived, one-use browser authorization state. tokenHash stores no bearer state token.
model OAuthState {
  id               String    @id @default(uuid())
  tokenHash        String    @unique
  browserBindingHash String?
  provider         String
  purpose          String
  appUserId        String
  encryptedPayload String?
  returnPath       String
  expiresAt        DateTime
  consumedAt       DateTime?
  createdAt        DateTime  @default(now())

  @@index([provider, purpose, expiresAt])
  @@index([appUserId, consumedAt])
}

model AzureDevOpsConnection {
  id                 String              @id @default(uuid())
  orgSlug            String              @unique
  project            String?
  pat                String
  status             String              @default("active")
  connectedBy        String?
  createdAt          DateTime            @default(now())
  updatedAt          DateTime            @updatedAt
  scmConnection      ScmConnection?
  workItemConnection WorkItemConnection?
}

/// Provider-neutral SCM account. encryptedCredentials must contain only ciphertext.
/// AzureDevOpsConnection remains the compatibility source during incremental migration.
model ScmConnection {
  id                            String                      @id @default(uuid())
  provider                      ScmProvider
  externalAccountId             String?
  displayName                   String
  namespace                     String?
  baseUrl                       String?
  encryptedCredentials          String
  status                        IntegrationConnectionStatus @default(connected)
  capabilities                  Json?
  metadata                      Json?
  connectedBy                   String?
  legacyAzureDevOpsConnectionId String?                     @unique
  legacyAzureDevOpsConnection   AzureDevOpsConnection?      @relation(fields: [legacyAzureDevOpsConnectionId], references: [id], onDelete: SetNull)
  createdAt                     DateTime                    @default(now())
  updatedAt                     DateTime                    @updatedAt
  lastVerifiedAt                DateTime?
  projectBindings               ProjectBinding[]
  webhookDeliveries             WebhookDelivery[]

  @@unique([provider, externalAccountId])
  @@index([provider, status])
  @@index([connectedBy])
}

/// Provider-neutral issue tracker account. encryptedCredentials must contain only ciphertext.
model WorkItemConnection {
  id                            String                      @id @default(uuid())
  provider                      WorkItemProvider
  externalAccountId             String?
  displayName                   String
  namespace                     String?
  baseUrl                       String?
  encryptedCredentials          String
  status                        IntegrationConnectionStatus @default(connected)
  capabilities                  Json?
  metadata                      Json?
  connectedBy                   String?
  legacyAzureDevOpsConnectionId String?                     @unique
  legacyAzureDevOpsConnection   AzureDevOpsConnection?      @relation(fields: [legacyAzureDevOpsConnectionId], references: [id], onDelete: SetNull)
  createdAt                     DateTime                    @default(now())
  updatedAt                     DateTime                    @updatedAt
  lastVerifiedAt                DateTime?
  projectBindings               ProjectBinding[]
  identityBindings              ExternalIdentityBinding[]
  snapshots                     WorkItemSnapshot[]
  webhookDeliveries             WebhookDelivery[]
  githubAttachments             GitHubAttachment[]

  @@unique([provider, externalAccountId])
  @@index([provider, status])
  @@index([connectedBy])
}

/// App-managed encrypted bytes for GitHub Issues, scoped to one connection and issue.
model GitHubAttachment {
  id                   String             @id @default(uuid())
  workItemConnectionId String
  workItemConnection   WorkItemConnection @relation(fields: [workItemConnectionId], references: [id], onDelete: Cascade)
  externalProjectId    String
  externalItemId       String
  fileName             String
  contentType          String
  sizeBytes            Int
  sha256               String
  encryptedBlob        Bytes
  createdBy            String?
  createdAt            DateTime           @default(now())
  expiresAt            DateTime

  @@index([workItemConnectionId, externalItemId, createdAt])
  @@index([createdBy])
  @@index([expiresAt])
}

/// Binds an app-owned context to provider project/repository identifiers.
model ProjectBinding {
  id                   String              @id @default(uuid())
  bindingKey           String              @unique
  scmConnectionId      String?
  scmConnection        ScmConnection?      @relation(fields: [scmConnectionId], references: [id], onDelete: Cascade)
  workItemConnectionId String?
  workItemConnection   WorkItemConnection? @relation(fields: [workItemConnectionId], references: [id], onDelete: Cascade)
  externalProjectId    String
  projectKey           String?
  repositoryId         String?
  repositoryName       String?
  createdBy            String              @default("system")
  metadata             Json?
  createdAt            DateTime            @default(now())
  updatedAt            DateTime            @updatedAt

  @@index([createdBy])
}

model ExternalIdentityBinding {
  id                   String             @id @default(uuid())
  workItemConnectionId String
  workItemConnection   WorkItemConnection @relation(fields: [workItemConnectionId], references: [id], onDelete: Cascade)
  appUserId            String?
  externalUserId       String
  externalLogin        String?
  externalEmail        String?
  displayName          String?
  createdAt            DateTime           @default(now())
  updatedAt            DateTime           @updatedAt

  @@unique([workItemConnectionId, externalUserId])
  // A partial unique index for non-null appUserId is installed by migration.
  @@index([appUserId])
  @@index([externalEmail])
}

model WorkItemSnapshot {
  id                   String             @id @default(uuid())
  workItemConnectionId String
  workItemConnection   WorkItemConnection @relation(fields: [workItemConnectionId], references: [id], onDelete: Cascade)
  externalProjectId    String
  externalItemId       String
  version              String?
  state                String?
  payload              Json
  providerUpdatedAt    DateTime?
  capturedAt           DateTime           @default(now())
  updatedAt            DateTime           @updatedAt

  @@unique([workItemConnectionId, externalProjectId, externalItemId])
  @@index([state])
  @@index([providerUpdatedAt])
}

/// A release groups deployments and work items into one versioned unit that
/// moves through draft -> in_review -> approved -> released with an approval
/// trail and (optionally AI-generated) release notes.
model Release {
  id               String            @id @default(uuid())
  name             String
  version          String
  description      String?
  status           String            @default("draft")
  targetOrgId      String?
  targetOrg        OrgConnection?    @relation("ReleaseTargetOrg", fields: [targetOrgId], references: [id], onDelete: SetNull)
  releaseNotes     String?
  notesGeneratedAt DateTime?
  scheduledAt      DateTime?
  releasedAt       DateTime?
  createdBy        String            @default("system")
  createdAt        DateTime          @default(now())
  updatedAt        DateTime          @updatedAt
  items            ReleaseItem[]
  approvals        ReleaseApproval[]

  @@unique([name, version])
  @@index([status])
  @@index([createdBy])
}

/// One linked artifact inside a release: an internal deployment or an
/// external work item reference (provider + project + item id).
model ReleaseItem {
  id                 String   @id @default(uuid())
  releaseId          String
  release            Release  @relation(fields: [releaseId], references: [id], onDelete: Cascade)
  kind               String
  deploymentId       String?
  workItemProvider   String?
  workItemProjectId  String?
  workItemExternalId String?
  title              String?
  metadata           Json?
  addedBy            String   @default("system")
  createdAt          DateTime @default(now())

  @@index([releaseId])
  @@index([deploymentId])
}

/// Approval decisions are append-once per actor (change of mind requires a
/// new review round after the release returns to draft).
model ReleaseApproval {
  id        String   @id @default(uuid())
  releaseId String
  release   Release  @relation(fields: [releaseId], references: [id], onDelete: Cascade)
  actorId   String
  decision  String
  comment   String?
  createdAt DateTime @default(now())

  @@unique([releaseId, actorId])
}

/// User-defined SOQL query template for data seeding/replication — the
/// generic, DB-backed alternative to the built-in CONA templates. Templates
/// may declare {{variable}} placeholders that are filled at compile time.
model DataQueryTemplate {
  id           String   @id @default(uuid())
  name         String
  description  String?
  objectName   String
  soqlTemplate String
  variables    String[] @default([])
  /// Shared templates are visible to every user (read-only for non-owners).
  shared       Boolean  @default(false)
  createdBy    String   @default("system")
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  @@unique([createdBy, name])
  @@index([shared])
}

/// A deployment freeze window. While active (enabled + now within range) all
/// non-validation metadata deployments to the covered orgs are blocked. An
/// empty orgConnectionIds list freezes every org.
model FreezeWindow {
  id               String   @id @default(uuid())
  name             String
  reason           String?
  orgConnectionIds String[] @default([])
  startAt          DateTime
  endAt            DateTime
  enabled          Boolean  @default(true)
  createdBy        String   @default("system")
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  @@index([enabled, startAt, endAt])
}

/// Automated scratch org renewal. N days before the tracked scratch org
/// expires, the original creation pipeline is replayed with a fresh alias so a
/// fully configured replacement (metadata, custom settings, data seed,
/// partners, users) is ready before the old org expires. After a successful
/// renewal the rule rolls forward to track the replacement org, keeping the
/// cycle going indefinitely.
model ScratchOrgRenewal {
  id                    String    @id @default(uuid())
  name                  String
  /// Alias of the scratch org currently tracked (rolls forward after renewal).
  scratchOrgAlias       String    @unique
  /// Sanitized copy of the source pipeline AutomationRun.config replayed on renewal.
  configSnapshot        Json
  /// AutomationRun the snapshot was captured from (provenance only).
  sourceAutomationRunId String?
  daysBeforeExpiry      Int       @default(2)
  enabled               Boolean   @default(true)
  /// Renewal fire time = tracked org expiration - daysBeforeExpiry; claimed atomically per tick.
  nextRunAt             DateTime?
  /// Expiration of the tracked org when nextRunAt was computed (display + retry bound).
  trackedExpirationDate DateTime?
  /// Pipeline run started by this renewal that is still being watched.
  activeAutomationRunId String?
  /// Alias of the replacement org the active run is creating.
  activeRunAlias        String?
  lastRunAt             DateTime?
  lastRunStatus         String?
  lastError             String?
  createdBy             String    @default("system")
  createdAt             DateTime  @default(now())
  updatedAt             DateTime  @updatedAt
  runs                  ScratchOrgRenewalRun[]

  @@index([createdBy])
  @@index([enabled, nextRunAt])
  @@index([activeAutomationRunId])
}

/// One renewal execution — scheduled or manual — for run history.
model ScratchOrgRenewalRun {
  id              String            @id @default(uuid())
  renewalId       String
  renewal         ScratchOrgRenewal @relation(fields: [renewalId], references: [id], onDelete: Cascade)
  trigger         String            @default("schedule")
  status          String            @default("started")
  /// Alias of the org being replaced when the run started.
  sourceAlias     String?
  /// Alias of the replacement org this run created.
  newAlias        String?
  automationRunId String?
  error           String?
  createdBy       String            @default("system")
  startedAt       DateTime          @default(now())
  finishedAt      DateTime?

  @@index([renewalId, startedAt])
}

/// Tracks sandbox refresh lifecycle per org connection: manual/requested
/// refreshes, cadence reminders, and the post-refresh automation to re-run.
model SandboxRefresh {
  id               String    @id @default(uuid())
  orgConnectionId  String
  sandboxName      String
  status           String    @default("requested")
  notes            String?
  /// Reminder cadence in days (e.g. 30); drives nextRefreshDueAt.
  cadenceDays      Int?
  nextRefreshDueAt DateTime?
  /// Post-refresh automation switches (org setup / data seed jobs to enqueue).
  postRefreshConfig Json?
  automationRunId  String?
  requestedBy      String    @default("system")
  requestedAt      DateTime  @default(now())
  completedAt      DateTime?
  updatedAt        DateTime  @updatedAt

  @@index([orgConnectionId, requestedAt])
  @@index([status])
}

/// One Apex test execution against an org, with the parsed summary and
/// per-test results. Runs are fired from the Quality dashboard.
model ApexTestRun {
  id              String    @id @default(uuid())
  orgConnectionId String
  alias           String
  testLevel       String    @default("RunLocalTests")
  status          JobStatus @default(running)
  outcome         String?
  testsRan        Int?
  passing         Int?
  failing         Int?
  skipped         Int?
  testRunCoverage Float?
  orgWideCoverage Float?
  summary         Json?
  tests           Json?
  error           String?
  requestedBy     String    @default("system")
  startedAt       DateTime  @default(now())
  finishedAt      DateTime?

  @@index([orgConnectionId, startedAt])
  @@index([requestedBy])
}

/// Point-in-time org-wide Apex coverage, captured on demand and after each
/// test run so the Quality dashboard can chart the trend.
model OrgCoverageSnapshot {
  id              String   @id @default(uuid())
  orgConnectionId String
  percentCovered  Float
  source          String   @default("manual")
  capturedAt      DateTime @default(now())

  @@index([orgConnectionId, capturedAt])
}

/// Outbound chat webhook (Slack or Microsoft Teams). The webhook URL is
/// encrypted at rest; an empty categories list means "all categories".
model NotificationChannelWebhook {
  id            String    @id @default(uuid())
  type          String
  name          String
  encryptedUrl  String
  enabled       Boolean   @default(true)
  categories    String[]  @default([])
  createdBy     String    @default("system")
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
  lastSuccessAt DateTime?
  lastErrorAt   DateTime?
  lastError     String?

  @@index([enabled])
}

/// Tracks the last notified change per external work item so webhook-driven
/// Developer Board alerts never notify the same revision twice and email
/// bursts are rate limited per item.
model WorkItemChangeNotification {
  id                String    @id @default(uuid())
  provider          String    @default("azure_boards")
  externalProjectId String
  externalItemId    String
  lastRevision      Int?
  lastChangedDate   DateTime?
  lastNotifiedAt    DateTime  @default(now())
  lastEmailAt       DateTime?
  updatedAt         DateTime  @updatedAt

  @@unique([provider, externalProjectId, externalItemId], map: "WorkItemChangeNotification_item_key")
  @@index([lastNotifiedAt])
}

/// The unique idempotencyKey makes webhook receipt safe to retry.
model WebhookDelivery {
  id                   String              @id @default(uuid())
  idempotencyKey       String              @unique
  connectionScope      String
  provider             String
  externalDeliveryId   String
  eventType            String
  payloadHash          String
  status               String              @default("received")
  attempts             Int                 @default(0)
  error                String?
  scmConnectionId      String?
  scmConnection        ScmConnection?      @relation(fields: [scmConnectionId], references: [id], onDelete: SetNull)
  workItemConnectionId String?
  workItemConnection   WorkItemConnection? @relation(fields: [workItemConnectionId], references: [id], onDelete: SetNull)
  receivedAt           DateTime            @default(now())
  processedAt          DateTime?
  updatedAt            DateTime            @updatedAt

  @@unique([provider, connectionScope, externalDeliveryId])
  @@index([status, receivedAt])
}

model ScratchPipelineTemplate {
  id          String   @id @default(uuid())
  name        String
  description String?
  isSystem    Boolean  @default(false)
  createdById String?
  config      Json
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([createdById])
  @@index([isSystem])
}

model IntelligentDeployRun {
  id           String                   @id @default(uuid())
  deploymentId String?
  targetOrgId  String?
  projectRoot  String
  manifestPath String
  deployMode   String                   @default("azure_manifest")
  status       JobStatus                @default(pending)
  checkpoint   Json?
  plan         Json?
  metrics      Json?
  createdBy    String                   @default("system")
  createdAt    DateTime                 @default(now())
  updatedAt    DateTime                 @updatedAt
  batches      IntelligentDeployBatch[]
  nodes        IntelligentDeployNode[]

  @@index([deploymentId])
  @@index([status])
  @@index([createdBy])
}

model IntelligentDeployBatch {
  id           String               @id @default(uuid())
  runId        String
  run          IntelligentDeployRun @relation(fields: [runId], references: [id], onDelete: Cascade)
  batchNumber  Int
  nodeCount    Int
  status       String               @default("pending")
  manifestPath String?
  durationMs   Int?
  error        String?
  createdAt    DateTime             @default(now())
  updatedAt    DateTime             @updatedAt

  @@unique([runId, batchNumber])
  @@index([runId])
}

model IntelligentDeployNode {
  id              String               @id @default(uuid())
  runId           String
  run             IntelligentDeployRun @relation(fields: [runId], references: [id], onDelete: Cascade)
  nodeKey         String
  metadataType    String
  apiName         String
  deploymentState String               @default("DISCOVERED")
  batchNumber     Int?
  retryCount      Int                  @default(0)
  lastError       Json?
  createdAt       DateTime             @default(now())
  updatedAt       DateTime             @updatedAt

  @@unique([runId, nodeKey])
  @@index([runId])
  @@index([deploymentState])
}

model LearnedDependency {
  id          String   @id @default(uuid())
  fromNodeKey String
  toNodeKey   String
  source      String   @default("learned")
  confidence  Float    @default(0.9)
  hitCount    Int      @default(1)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@unique([fromNodeKey, toNodeKey])
  @@index([fromNodeKey])
}

/* ------------------------------------------------------------------ */
/* Salesforce Academy (learning module)                                */
/*                                                                     */
/* Curriculum content is versioned in code (apps/api learning module); */
/* the database only captures per-user training state so admin reports */
/* survive curriculum updates.                                         */
/* ------------------------------------------------------------------ */

/// Admin-assigned learning path for a user. status: active | revoked.
model LearningAssignment {
  id         String    @id @default(uuid())
  userId     String
  pathId     String
  assignedBy String
  note       String?
  dueAt      DateTime?
  status     String    @default("active")
  createdAt  DateTime  @default(now())
  updatedAt  DateTime  @updatedAt

  @@unique([userId, pathId])
  @@index([userId, status])
  @@index([pathId, status])
  @@index([assignedBy])
}

/// One row per lesson a user has completed (idempotent on re-complete).
model LearningLessonProgress {
  id          String   @id @default(uuid())
  userId      String
  pathId      String
  moduleId    String
  lessonId    String
  completedAt DateTime @default(now())

  @@unique([userId, lessonId])
  @@index([userId, pathId])
  @@index([userId, moduleId])
  @@index([pathId, completedAt])
}

/// Server-scored quiz session. `questions` retains the full question set
/// INCLUDING correct answers + explanations (never sent to the client while
/// status = in_progress); `answers` stores the learner's submission for review.
model LearningQuizAttempt {
  id             String    @id @default(uuid())
  userId         String
  pathId         String
  moduleId       String
  status         String    @default("in_progress")
  source         String    @default("static")
  questions      Json
  answers        Json?
  totalQuestions Int
  correctCount   Int       @default(0)
  scorePercent   Int       @default(0)
  passed         Boolean   @default(false)
  startedAt      DateTime  @default(now())
  completedAt    DateTime?
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt

  @@index([userId, moduleId, status])
  @@index([userId, pathId])
  @@index([moduleId, passed])
  @@index([userId, completedAt])
}
