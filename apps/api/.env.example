# docker-compose maps Postgres to host port 55432 (see docker-compose.yml)
DATABASE_URL="postgresql://sfcc:sfcc_dev_password@localhost:55432/sfcc?schema=public"
REDIS_URL="redis://localhost:6379"
API_PORT=3001
# Comma-separated allowed browser origins in production (e.g. http://localhost:8080,http://localhost:3000)
# CORS_ORIGINS="http://localhost:8080,http://localhost:3000"
# Set SWAGGER_ENABLED=false in production to hide /api/docs
ENCRYPTION_KEY="generate-a-64-char-hex-string-here"
# Global API request ceiling per client IP per minute (default 1200)
# API_RATE_LIMIT_PER_MINUTE=1200

# NVIDIA NIM — primary key (Gemma) + optional fallback key (Nemotron)
NVIDIA_API_KEY="nvapi-your-gemma-key-here"
NVIDIA_FALLBACK_API_KEY="nvapi-your-nemotron-key-here"
NVIDIA_BASE_URL="https://integrate.api.nvidia.com/v1"
# Default is fast + reliable; avoid google/gemma-3n-e4b-it if requests hang
NVIDIA_COPILOT_MODEL="meta/llama-3.2-3b-instruct"
NVIDIA_PRIMARY_MODEL="meta/llama-3.2-3b-instruct"
NVIDIA_FALLBACK_MODEL="nvidia/llama-3.3-nemotron-super-49b-v1.5"
NVIDIA_EMBEDDING_MODEL="nvidia/nv-embedqa-e5-v5"
NVIDIA_COPILOT_FAST_TIMEOUT_MS=10000
NVIDIA_CLIENT_TIMEOUT_MS=120000
NVIDIA_CHAT_TIMEOUT_MS=90000

# Open-source Academy media stack (all optional; see docs/academy-open-media-plan.md).
#
# EASIEST SETUP — hosted Hugging Face Spaces (no GPU of your own). Each tier
# prefers its *_SPACE_URL when set; self-hosted URLs below remain supported.
QWEN_TTS_SPACE_URL="https://qwen-qwen3-tts.hf.space"
QWEN_TTS_SPACE_API="/generate_custom_voice"
ZIMAGE_SPACE_URL="https://mrfakename-z-image-turbo.hf.space"
# ZIMAGE_SPACE_API="/generate_image"   # default; override only if your Space uses a different fn name
WAN_VIDEO_SPACE_URL="https://kulkas2pintu-wan555.hf.space"
# WAN_VIDEO_SPACE_API="/generate_video"
# Hugging Face token — strongly recommended: public ZeroGPU Spaces reject or
# throttle anonymous callers for long jobs (voice + video especially).
# HF_TOKEN="hf_..."
# QWEN_TTS_MODEL_SIZE="1.7B"
# HF_SPEECH_TIMEOUT_MS=300000
# HF_IMAGE_TIMEOUT_MS=120000
# HF_VIDEO_TIMEOUT_MS=480000
# ZIMAGE_STEPS=9
# WAN_VIDEO_STEPS=4
# WAN_VIDEO_DURATION_SECONDS=2.5

# Voice — legacy VibeVoice Space (used only when QWEN_TTS_SPACE_URL is unset)
# VIBEVOICE_SPACE_URL="https://steveeeeeeen-vibevoice-large.hf.space"
# VIBEVOICE_CFG_SCALE=1.3

# Voice — self-hosted Microsoft VibeVoice behind any OpenAI-compatible server
# (e.g. vibevoice-community/VibeVoice-API): POST {base}/v1/audio/speech
VIBEVOICE_BASE_URL=""
# VIBEVOICE_API_KEY=""
# VIBEVOICE_MODEL="vibevoice"
# VIBEVOICE_TIMEOUT_MS=60000
# VIBEVOICE_ENABLED=true

# Scene art — FLUX.1-schnell / SDXL behind a Stable-Diffusion-WebUI-compatible
# API (AUTOMATIC1111 / Forge / SD.Next / ComfyUI sdapi wrappers): /sdapi/v1/txt2img
SD_WEBUI_BASE_URL=""
# SD_IMAGE_MODEL="flux1-schnell-fp8.safetensors"
# SD_IMAGE_STEPS=20            # FLUX.1-schnell: 4
# SD_IMAGE_CFG_SCALE=7         # FLUX.1-schnell: 1
# SD_IMAGE_SAMPLER="Euler a"
# SD_IMAGE_WIDTH=1280
# SD_IMAGE_HEIGHT=720
# SD_IMAGE_TIMEOUT_MS=60000
# SD_IMAGE_ENABLED=true

# Motion scenes — ComfyUI + LTX-Video (or Wan 2.2 via a custom workflow template)
COMFYUI_BASE_URL=""
# COMFYUI_VIDEO_WORKFLOW="/path/to/workflow-template.json"
# COMFYUI_VIDEO_CHECKPOINT="ltx-video-2b-v0.9.5.safetensors"
# COMFYUI_TEXT_ENCODER="t5xxl_fp16.safetensors"
# COMFYUI_VIDEO_WIDTH=768
# COMFYUI_VIDEO_HEIGHT=512
# COMFYUI_VIDEO_FRAMES=97
# COMFYUI_VIDEO_FPS=24
# COMFYUI_VIDEO_TIMEOUT_MS=180000
# COMFYUI_VIDEO_ENABLED=true

# Salesforce Academy AI budgets
LEARNING_QUIZ_AI_TIMEOUT_MS=25000
LEARNING_TUTOR_TIMEOUT_MS=30000
LEARNING_EXPLAINER_TIMEOUT_MS=30000

# Academy video sessions (admin-uploaded lesson videos)
# Files land on the API server's disk; metadata lives in Postgres.
# LEARNING_VIDEO_DIR="/var/lib/sfcc/learning-videos"   # default: <api cwd>/uploads/learning-videos
# LEARNING_VIDEO_MAX_MB=1024

# Azure DevOps (metadata deploy defaults)
AZURE_DEVOPS_ORG="ajayshetty200026"
AZURE_DEVOPS_PAT=""
AZURE_DEFAULT_PROJECT="DPT TOOL TEST"
AZURE_DEFAULT_REPO="DPT TOOL TEST"
AZURE_DEFAULT_BRANCH="master"
AZURE_DEFAULT_MANIFEST_PATH="CoreFlex Onboarding/manifest/package.xml"
# Intelligent metadata deploy (default on; set false for monolithic fallback)
INTELLIGENT_DEPLOY_ENABLED=true

# Salesforce CLI plugin provisioning. Only the application allowlist (SFDMU
# and Salesforce Code Analyzer) can be installed; arbitrary names are rejected.
SF_CLI_PATH="sf"
# Auto-detected in standard layouts. Set this to the directory containing
# sfdx-project.json and config/ only when the API runs from a custom location.
# SF_PROJECT_ROOT="/absolute/path/to/sf-devops-command-center"
SF_AUTO_INSTALL_PLUGINS=true
SF_ENFORCE_PLUGIN_VERSIONS=true
SFDMU_PLUGIN_VERSION=5.8.0
SF_CODE_ANALYZER_PLUGIN_VERSION=5.14.0
SF_PLUGIN_INSTALL_TIMEOUT_MS=600000
# Set false only if partial/skipped SFDMU writes should be treated as successful.
SFDMU_FAIL_ON_WARNING=true
# Leave false to require Salesforce plugin signature verification.
SF_ALLOW_UNSIGNED_SFDMU=false

# SFDMU working dir (default: OS temp). CSV/config artifacts are deleted after each deploy.
# SFDMU_RUNS_DIR="/tmp/sfcc-sfdmu-runs"
# SFDMU_KEEP_RUN_ARTIFACTS=true

# Data deploy load balancing (100k+ records)
DATA_DEPLOY_CHUNK_SIZE=25000
DATA_DEPLOY_CONCURRENCY=2
SFDMU_RUN_CONCURRENCY=2
SF_DATA_BULK_WAIT_MINUTES=60
SF_MAX_CONCURRENT_BULK_PER_ORG=2

# Prometheus scrape auth (recommended in production; endpoint is hidden in
# production when unset). Configure your scraper with: Authorization: Bearer <token>
# METRICS_TOKEN="generate-a-long-random-token"

# Outbound email (optional — enables the email notification channel)
# SMTP_HOST="smtp.example.com"
# SMTP_PORT=587
# SMTP_SECURE=false
# SMTP_USER=""
# SMTP_PASS=""
# MAIL_FROM="SF DevOps Command Center <no-reply@example.com>"
# Absolute base URL used in email deep links (e.g. https://devops.example.com)
# PUBLIC_APP_URL=""

# Developer Board work-item webhooks (optional — set to enable /api/defects/webhooks/*)
# DEFECTS_WEBHOOK_SECRET="generate-a-long-random-secret"

# Firebase — must match the web app's NEXT_PUBLIC_FIREBASE_PROJECT_ID
FIREBASE_PROJECT_ID="your-project-id"
# Web API key (same as NEXT_PUBLIC_FIREBASE_API_KEY) — used for server-proxied login/signup
FIREBASE_WEB_API_KEY=""

# Comma-separated emails that auto-receive admin role on first login (optional)
# ADMIN_EMAILS="admin@example.com"

# Secret for operator-only admin bootstrap — visit /login?bootstrap=YOUR_SECRET once, then sign up or sign in
# ADMIN_BOOTSTRAP_SECRET="generate-a-long-random-secret-here"

# Firebase Admin SDK (optional — enables user sync in Admin → User Access)
# Option A: paste service account fields from Firebase Console
FIREBASE_CLIENT_EMAIL=""
FIREBASE_PRIVATE_KEY=""
# Option B: path to downloaded service account JSON (recommended)
# FIREBASE_SERVICE_ACCOUNT_PATH="/path/to/service-account.json"
