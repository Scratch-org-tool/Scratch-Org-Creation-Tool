# API URL — leave as localhost for same-machine dev.
# Use the gateway (http://localhost:8080) as the single entry point when GATEWAY_ENABLED=1.
# Other devices on your Wi-Fi can use the gateway URL (API is proxied automatically).
NEXT_PUBLIC_API_URL="http://localhost:3001"
API_INTERNAL_URL="http://localhost:3001"
API_UPSTREAMS="http://localhost:3001"

# Firebase client SDK — from Firebase Console → Project settings → Your apps → Web app
NEXT_PUBLIC_FIREBASE_API_KEY="your-api-key"
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN="your-project.firebaseapp.com"
NEXT_PUBLIC_FIREBASE_PROJECT_ID="your-project-id"
NEXT_PUBLIC_FIREBASE_STORAGE_BUCKET="your-project.firebasestorage.app"
NEXT_PUBLIC_FIREBASE_MESSAGING_SENDER_ID="your-sender-id"
NEXT_PUBLIC_FIREBASE_APP_ID="your-app-id"
NEXT_PUBLIC_FIREBASE_MEASUREMENT_ID="G-XXXXXXXXXX"
