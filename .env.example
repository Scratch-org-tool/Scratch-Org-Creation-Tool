# Database (docker-compose maps Postgres to host port 55432 to avoid clashing
# with a locally installed Postgres; using your own Postgres on 5432 works too)
DATABASE_URL="postgresql://sfcc:sfcc_dev_password@localhost:55432/sfcc?schema=public"

# Redis
REDIS_URL="redis://localhost:6379"

# API
API_PORT=3001
API_URL="http://localhost:3001"
NEXT_PUBLIC_API_URL="http://localhost:3001"
# Comma-separated pool for gateway / Next.js rewrites (first entry is primary)
API_UPSTREAMS="http://localhost:3001"
API_INTERNAL_URL="http://localhost:3001"

# Top-level gateway (load balancer) — enabled by default via npm run dev
GATEWAY_PORT=8080
GATEWAY_ENABLED=1
WEB_UPSTREAM="http://127.0.0.1:3000"
# Production API clustering: npm run start:cluster --workspace=@sfcc/api
API_WORKERS=4

# Encryption (32-byte hex key for AES-256-GCM token encryption)
ENCRYPTION_KEY="generate-a-64-char-hex-string-here"

# NVIDIA NIM — primary key (Gemma) + optional fallback key (Nemotron)
NVIDIA_API_KEY="nvapi-your-gemma-key-here"
NVIDIA_FALLBACK_API_KEY="nvapi-your-nemotron-key-here"
NVIDIA_BASE_URL="https://integrate.api.nvidia.com/v1"
# Default is fast + reliable; avoid google/gemma-3n-e4b-it if requests hang
NVIDIA_COPILOT_MODEL="meta/llama-3.2-3b-instruct"
NVIDIA_PRIMARY_MODEL="meta/llama-3.2-3b-instruct"
NVIDIA_FALLBACK_MODEL="nvidia/llama-3.3-nemotron-super-49b-v1.5"
NVIDIA_EMBEDDING_MODEL="nvidia/nv-embedqa-e5-v5"
NVIDIA_COPILOT_FAST_TIMEOUT_MS=10000
NVIDIA_CLIENT_TIMEOUT_MS=120000
NVIDIA_CHAT_TIMEOUT_MS=90000

# Firebase (client - web app uses NEXT_PUBLIC_FIREBASE_* in apps/web/.env.local)
FIREBASE_PROJECT_ID="automation-tool-29a9c"
# Firebase Admin (API server) - download service account JSON from Firebase Console
FIREBASE_CLIENT_EMAIL="firebase-adminsdk@automation-tool-29a9c.iam.gserviceaccount.com"
FIREBASE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----\n"

# Azure DevOps
AZURE_DEVOPS_ORG="ajayshetty200026"
AZURE_DEVOPS_PAT=""
AZURE_DEFAULT_PROJECT="DPT TOOL TEST"
AZURE_DEFAULT_REPO="DPT TOOL TEST"
AZURE_DEFAULT_BRANCH="master"
AZURE_DEFAULT_MANIFEST_PATH="CoreFlex Onboarding/manifest/package.xml"

# Jenkins
JENKINS_URL=""
JENKINS_USER=""
JENKINS_TOKEN=""

# Datadog (optional)
DATADOG_API_KEY=""
DATADOG_APP_KEY=""

# Outbound email (optional — enables the email notification channel)
# SMTP_HOST="smtp.example.com"
# SMTP_PORT=587
# SMTP_SECURE=false
# SMTP_USER=""
# SMTP_PASS=""
# MAIL_FROM="SF DevOps Command Center <no-reply@example.com>"
# PUBLIC_APP_URL=""

# Developer Board work-item webhooks (optional)
# DEFECTS_WEBHOOK_SECRET="generate-a-long-random-secret"

# Salesforce CLI
SF_CLI_PATH="sf"
# The API provisions only its two allowlisted user plugins (SFDMU + Code Analyzer).
SF_AUTO_INSTALL_PLUGINS=true
SF_ENFORCE_PLUGIN_VERSIONS=true
SFDMU_PLUGIN_VERSION=5.8.0
SF_CODE_ANALYZER_PLUGIN_VERSION=5.14.0
SF_PLUGIN_INSTALL_TIMEOUT_MS=600000
# Keep signature verification enabled. Set true only for a private/offline
# registry after explicitly accepting the unsigned SFDMU trust boundary.
SF_ALLOW_UNSIGNED_SFDMU=false
